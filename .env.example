# Sports Media Protection — Environment Variables
# Copy to .env for local development. Never commit .env to git.
# For Cloud Run: set these via --set-env-vars or Secret Manager.

# ── Database ─────────────────────────────────────────────────────────────────
# Local Docker Compose:
DATABASE_URL=postgresql://smp_user:changeme@postgres:5432/smp_db
# Cloud SQL Unix socket (Cloud Run):
# DATABASE_URL=postgresql+psycopg2://smp_user:PASSWORD@/smp_db?host=/cloudsql/PROJECT:REGION:INSTANCE

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GOOGLE_AI_ENABLED=true
GEMINI_MODEL=gemini-2.0-flash

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=/app/data
FAISS_INDEX_PATH=/app/data/indices/visual.index
DL_INDEX_PATH=/app/data/indices/dl.index

# ── App settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_VIDEO_SIZE_MB=500
FRAME_SAMPLE_RATE=1
HASH_SIZE=16
MATCH_THRESHOLD=0.85

# ── CORS (set to your Cloud Run URL in production) ────────────────────────────
# Example: ALLOWED_ORIGINS=https://smp-api-abc123-uc.a.run.app
ALLOWED_ORIGINS=*

# ── PostgreSQL (docker-compose only) ──────────────────────────────────────────
POSTGRES_USER=smp_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=smp_db
